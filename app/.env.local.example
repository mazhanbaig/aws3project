# Copy this file to .env.local and uncomment the appropriate section

# Option 1: Use a local PostgreSQL database
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=competitor_tracker
# DB_USER=postgres
# DB_PASSWORD=your_local_password

# Option 2: Use the production RDS instance (for development/testing)
# DB_HOST=your-rds-endpoint.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=competitor_tracker
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# JWT secret for authentication
JWT_SECRET=local-dev-secret-change-in-production

# S3 bucket for screenshots
S3_BUCKET_NAME=competitor-tracker-snapshots
AWS_REGION=us-east-1
